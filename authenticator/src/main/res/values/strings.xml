    <!-- Permission Rationale -->
    <string name="permission_rationale_title">Why These Permissions?</string>
    <string name="permission_rationale_message">WearAuthn is a Bluetooth security key that needs these permissions:\n\n🔐 <b>Bluetooth Advertise</b>\nTo act as a FIDO2/U2F security key\n\n📡 <b>Bluetooth Scan</b>\nTo discover other security devices\n\n🔗 <b>Bluetooth Connect</b>\nTo communicate securely with devices\n\nYour privacy is protected - we only use Bluetooth for security authentication.</string>

    <!-- Permission Denied -->
    <string name="permission_denied_title">Permissions Required</string>
    <string name="permission_denied_message">Bluetooth permissions are required for WearAuthn to work. You can grant them in Settings > Apps > WearAuthn > Permissions.</string>

