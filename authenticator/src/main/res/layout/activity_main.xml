<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Toolbar with logo, title and settings icon -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/app_name" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_subtitle"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:alpha="0.8" />

            </LinearLayout>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Authentication Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Authentication Status: Ready"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Status"
                        android:textSize="11sp"
                        android:enabled="false"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bluetooth & BLE Operations Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header with Bluetooth icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:text="📶"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bluetooth &amp; BLE Operations"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                    </LinearLayout>

                    <!-- Bluetooth Status Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bluetooth Status"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:id="@+id/bluetoothStatusTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Checking..."
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bluetoothToggleButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Enable"
                            android:textSize="12sp"
                            android:enabled="false"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginVertical="8dp" />

                    <!-- Advertise Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Advertise as Security Key"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:id="@+id/advertisingNameTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Device: CrayonicB12345"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/advertiseButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="@string/advertise_button"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginVertical="8dp" />

                    <!-- Scan Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Scan for BLE Devices"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Discover nearby security keys"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/scanButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="@string/scan_button"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Main Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/manageCredentialsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/manage_credentials_button"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TextButton" />

            <!-- Spacer to push test button to bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Test Authentication at Bottom -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/testAuthenticationButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/test_authentication_button"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />



        </LinearLayout>

    </ScrollView>

</LinearLayout>
